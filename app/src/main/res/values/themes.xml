<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme -->
    <style name="Theme.SmartSpend" parent="android:Theme.Material.Light.NoActionBar" />
    
    <!-- Splash Screen Theme (Android 12+) -->
    <!-- Uses the new adaptive icon which has proper sizing -->
    <style name="Theme.SmartSpend.Splash" parent="Theme.SmartSpend">
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/splash_background</item>
    </style>
</resources>
